{
  "appId": "com.knails.finance",
  "appName": "K Nails Finance",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "backgroundColor": "#FAF7F2"
  },
  "ios": {
    "contentInset": "always",
    "scrollEnabled": true,
    "preferredContentMode": "mobile",
    "backgroundColor": "#FAF7F2"
  },
  "plugins": {
    "Browser": {
      "presentationStyle": "popover"
    }
  }
}
